echo "🔒 Pre-push security checks..."

# 1. Secrets scan no histórico completo do branch
if command -v gitleaks &> /dev/null; then
  echo "  [1/2] Full history secrets scan..."
  gitleaks detect --config=.gitleaks.toml --no-banner
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ BLOCKED: Secrets found in commit history."
    echo "   Use 'git filter-repo' ou BFG Repo Cleaner para remover."
    echo "   Depois revogue as credenciais comprometidas IMEDIATAMENTE."
    exit 1
  fi
  echo "  ✓ History clean"
fi

# 2. Auditoria rápida de dependências críticas (usa bun — sem package-lock.json)
echo "  [2/2] Critical dependency audit..."
if command -v bun &> /dev/null; then
  bun audit 2>/dev/null | grep -q "critical:" && {
    echo ""
    echo "❌ BLOCKED: Critical CVEs in dependencies."
    echo "   Execute 'bun update' para atualizar as dependências afetadas."
    exit 1
  }
fi
echo "  ✓ No critical CVEs"

echo ""
echo "✅ Pre-push checks passed. Pushing..."
