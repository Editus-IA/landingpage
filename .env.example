# Supabase — pegue em: Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...   # service_role key — NUNCA exponha no frontend

# Salt para anonimização de IPs (LGPD) — obrigatório em produção
# Gere com: openssl rand -hex 32
# NUNCA commitar o valor real, apenas este placeholder
IP_HASH_SALT=

# Upstash Redis — rate limiting persistente em serverless (opcional; fallback em memória se ausente)
# Pegue em: console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — pegue em: resend.com → API Keys
RESEND_API_KEY=

# Umami self-hosted — valores públicos (aparecem no HTML)
NUXT_PUBLIC_UMAMI_SCRIPT_URL=https://umami.exemplo.com.br/script.js
NUXT_PUBLIC_UMAMI_WEBSITE_ID=

# Sentry — pegue em: sentry.io → Project Settings → Client Keys (DSN)
# DSN é público por design (aparece no bundle JS do cliente)
SENTRY_DSN=

# NÃO use NUXT_PUBLIC_ aqui — essas variáveis ficam APENAS no servidor
